    {"type":"text","id":"col1_path","x":100,"y":255,"width":500,"height":22,"text":"fetchUser.ts","originalText":"fetchUser.ts","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40011,"version":1,"versionNonce":40012,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"col1_code","x":100,"y":285,"width":500,"height":225,"text":"async function getUser(id) {\n  for (let i = 0; i < 3; i++) {\n    try {\n      const r = await fetch(`/u/${id}`);\n      if (!r.ok) throw new Error();\n      return await r.json();\n    } catch (e) {\n      await sleep(2 ** i * 100);\n    }\n  }\n  throw new Error('failed');\n}","originalText":"async function getUser(id) {\n  for (let i = 0; i < 3; i++) {\n    try {\n      const r = await fetch(`/u/${id}`);\n      if (!r.ok) throw new Error();\n      return await r.json();\n    } catch (e) {\n      await sleep(2 ** i * 100);\n    }\n  }\n  throw new Error('failed');\n}","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40013,"version":1,"versionNonce":40014,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

