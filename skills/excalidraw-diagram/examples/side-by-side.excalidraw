    {"type":"text","id":"col2_s","x":700,"y":200,"width":540,"height":22,"text":"declarative retry via withRetry helper","originalText":"declarative retry via withRetry helper","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40017,"version":1,"versionNonce":40018,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

