    {"type":"text","id":"col2_path","x":720,"y":255,"width":500,"height":22,"text":"fetchUser.ts","originalText":"fetchUser.ts","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#94a3b8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40021,"version":1,"versionNonce":40022,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"col2_code","x":720,"y":285,"width":500,"height":225,"text":"const getUser = withRetry(\n  async (id) => {\n    const r = await fetch(`/u/${id}`);\n    if (!r.ok) throw new Error();\n    return r.json();\n  },\n  { tries: 3, backoff: 'exp' }\n);","originalText":"const getUser = withRetry(\n  async (id) => {\n    const r = await fetch(`/u/${id}`);\n    if (!r.ok) throw new Error();\n    return r.json();\n  },\n  { tries: 3, backoff: 'exp' }\n);","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40023,"version":1,"versionNonce":40024,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

    {"type":"text","id":"caption","x":80,"y":580,"width":1200,"height":22,"text":"Two parallel columns + dashed divider — same problem on each side, the difference does the talking.","originalText":"Two parallel columns + dashed divider — same problem on each side, the difference does the talking.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":40025,"version":1,"versionNonce":40026,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
